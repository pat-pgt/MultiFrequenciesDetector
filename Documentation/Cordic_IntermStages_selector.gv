							   <tr><td rowspan="4">op_S</td><td port="s3">b3</td>
							   		   <td rowspan="9">Add or sub</td><td rowspan="2">carry</td></tr>
							   <tr><td port="s2">b2</td></tr>
							   <tr><td port="s1">b1</td><td rowspan="2">b2</td></tr>
							   <tr><td port="s0">b0</td></tr>
							   <tr><td rowspan="4">op_N</td><td port="n3">b3</td><td rowspan="2">b1</td></tr>
							   <tr><td port="n2">b2</td></tr>
							   <tr><td port="n1">b1</td><td rowspan="2">b0</td></tr>
							   <tr><td port="n0">b0</td></tr>
							   <tr><td>op_C</td><td>carry</td></tr>
							   </table>> ];

				  label = "Output for add or sub";
				  }

 		 array_out_for_add_sub_4:zero:w -> array_out_for_add_sub_4:s3:w;
		 array_out_for_add_sub_4:zero:w -> array_out_for_add_sub_4:n3:w;
		 array_scz_in_4:sign_scz_in:e -> array_out_for_add_sub_4:s2:w [color="blue"];
		 array_scz_in_4:sign_scz_in:e -> array_out_for_add_sub_4:s1:w [color="blue"];
		 array_scz_in_4:sign_scz_in:e -> array_out_for_add_sub_4:s0:w [color="blue"];
		 array_scz_in_4:2:e -> array_out_for_add_sub_4:n2:w [color="blue"];
		 array_scz_in_4:1:e -> array_out_for_add_sub_4:n1:w [color="blue"];
		 array_scz_in_4:0:e -> array_out_for_add_sub_4:n0:w [color="blue"];

		 subgraph cluster_out_for_add_sub_extra_4 {
				  color=blue;
				  node[style=filled];
				  array_out_for_add_sub_extra_4 [ shape=plain label=<
				  			   <table border="0" cellborder="1" cellspacing="1" >
							   <tr><td rowspan="4">op_S</td><td port="s3">b3</td></tr>
							   <tr><td port="s2">b2</td></tr>
							   <tr><td port="s1">b1</td></tr>
							   <tr><td port="s0">b0</td></tr>
							   <tr><td rowspan="4">op_N</td><td port="n3">b3</td></tr>
							   <tr><td port="n2">b2</td></tr>
							   <tr><td port="n1">b1</td></tr>
							   <tr><td port="n0">b0</td></tr>
							   <tr><td>op_C</td><td>carry</td></tr>
							   </table>> ];

				  label = "Output for add or sub extra 1";
				  }
		 "zero" -> array_out_for_add_sub_extra_4:s3:w;
		 "zero" -> array_out_for_add_sub_extra_4:n3:w;
		 array_scz_out_4:sign_scz_out:e -> array_out_for_add_sub_extra_4:s2:w [color="orange"];
		 array_scz_out_4:sign_scz_out:e -> array_out_for_add_sub_extra_4:s1:w [color="orange"];
		 array_scz_out_4:sign_scz_out:e -> array_out_for_add_sub_extra_4:s0:w [color="orange"];
		 array_scz_out_4:2:e -> array_out_for_add_sub_extra_4:n2:w [color="orange"];
		 array_scz_out_4:1:e -> array_out_for_add_sub_extra_4:n1:w [color="orange"];
		 array_scz_out_4:0:e -> array_out_for_add_sub_extra_4:n0:w [color="orange"];

		 label = "Four clock cycles after reg_sync"
}