				  			   <table border="0" cellborder="1" cellspacing="1" >
							   <tr><td port="zero">0</td><td></td><td></td><td></td></tr>
							   <tr><td colspan="4"></td></tr>
							   <tr><td rowspan="4">op_S</td><td port="s3">b3</td>
							   		   <td rowspan="9">Add or sub</td><td rowspan="2">carry</td></tr>
							   <tr><td port="s2">b2</td></tr>
							   <tr><td port="s1">b1</td><td rowspan="2">b2</td></tr>
							   <tr><td port="s0">b0</td></tr>
							   <tr><td rowspan="4">op_N</td><td port="n3">b3</td><td rowspan="2">b1</td></tr>
							   <tr><td port="n2">b2</td></tr>
							   <tr><td port="n1">b1</td><td rowspan="2">b0</td></tr>
							   <tr><td port="n0">b0</td></tr>
							   <tr><td>op_C</td><td>carry</td></tr>
							   </table>> ];

				  label = "Output for add or sub base";
				  }


		 array_out_for_add_sub_1:zero:w -> array_out_for_add_sub_1:s3:w;
		 array_out_for_add_sub_1:zero:w -> array_out_for_add_sub_1:n3:w;
		 array_scz_in_1:6:e -> array_out_for_add_sub_1:s2:w [color="blue"];
		 array_scz_in_1:5:e -> array_out_for_add_sub_1:s1:w [color="blue"];
		 array_scz_in_1:4:e -> array_out_for_add_sub_1:s0:w [color="blue"];
		 array_scz_in_1:2:e -> array_out_for_add_sub_1:n2:w [color="blue"];
		 array_scz_in_1:1:e -> array_out_for_add_sub_1:n1:w [color="blue"];
		 array_scz_in_1:0:e -> array_out_for_add_sub_1:n0:w [color="blue"];

	 subgraph cluster_out_for_add_sub_extra_1 {
				  color=blue;
				  node[style=filled];
				  array_out_for_add_sub_extra_1 [ shape=plain label=<
				  			   <table border="0" cellborder="1" cellspacing="1" >
							   <tr><td></td><td port="zero">0</td></tr>
							   <tr><td colspan="2"></td></tr>
							   <tr><td rowspan="4">op_S</td><td port="s3">b3</td></tr>
							   <tr><td port="s2">b2</td></tr>
							   <tr><td port="s1">b1</td></tr>
							   <tr><td port="s0">b0</td></tr>
							   <tr><td rowspan="4">op_N</td><td port="n3">b3</td></tr>
							   <tr><td port="n2">b2</td></tr>
							   <tr><td port="n1">b1</td></tr>
							   <tr><td port="n0">b0</td></tr>
							   <tr><td>op_C</td><td>carry</td></tr>
							   </table>> ];

				  label = "Output for add or sub extra 1";
				  }
		 array_out_for_add_sub_extra_1:zero:w -> array_out_for_add_sub_extra_1:s3:w;
		 array_out_for_add_sub_extra_1:zero:w -> array_out_for_add_sub_extra_1:n3:w;
		 array_scz_out_1:7:e -> array_out_for_add_sub_extra_1:s2:w [color="red"];
		 array_scz_out_1:6:e -> array_out_for_add_sub_extra_1:s1:w [color="red"];
		 array_scz_out_1:5:e -> array_out_for_add_sub_extra_1:s0:w [color="red"];
		 array_scz_out_1:8:e -> array_out_for_add_sub_extra_1:s2:w [color="green"];
		 array_scz_out_1:7:e -> array_out_for_add_sub_extra_1:s1:w [color="green"];
		 array_scz_out_1:6:e -> array_out_for_add_sub_extra_1:s0:w [color="green"];
		 array_scz_out_1:2:e -> array_out_for_add_sub_extra_1:n2:w [color="orange"];
		 array_scz_out_1:1:e -> array_out_for_add_sub_extra_1:n1:w [color="orange"];
		 array_scz_out_1:0:e -> array_out_for_add_sub_extra_1:n0:w [color="orange"];

		 label = "One clock cycle after reg_sync"
}
