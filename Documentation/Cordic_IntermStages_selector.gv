digraph Step_1 {
		 rankdir="LR";
		 lanscape=true;
		 subgraph cluster_array_scz_in_1 {
		 		  style = dashed;
				  color=lightgray;
				  
				  array_scz_in_1 [ shape=plain label=<
				  			   <table border="0" cellborder="1" cellspacing="1" >
							   <tr><td>old</td><td port="sign_scz_in">b11</td></tr>
							   <tr><td colspan="2"></td></tr>
							   <tr><td rowspan="3">old</td><td port="11">b11</td></tr>
							   <tr><td port="10">b10</td></tr>
							   <tr><td port="9">b9</td></tr>
							   <tr><td rowspan="3">old</td><td port="8">b8</td></tr>
							   <tr><td port="7">b7</td></tr>
							   <tr><td port="6">b6</td></tr>
							   <tr><td rowspan="3">old</td><td port="5">b5</td></tr>
							   <tr><td port="4">b4</td></tr>
							   <tr><td port="3">b3</td></tr>
							   <tr><td rowspan="3">old</td><td port="2">b2</td></tr>
							   <tr><td port="1">b1</td></tr>
							   <tr><td port="0">b0</td></tr>
							   </table>> ];
				  label = "SCZ IN (from previous stage)";
				  }
		 subgraph cluster_scz_out_1 {
				  color=blue;
				  node[style=filled];
				  array_scz_out_1 [ shape=plain label=<
				  			   <table border="0" cellborder="1" cellspacing="1" >
							   <tr><td>old</td><td port="sign_scz_out">b11</td></tr>
							   <tr><td colspan="2"></td></tr>
							   <tr><td rowspan="3">old</td><td port="11">b11</td></tr>
							   <tr><td port="10">b10</td></tr>
							   <tr><td port="9">b9</td></tr>
							   <tr><td rowspan="3">old</td><td port="8">b8</td></tr>
							   <tr><td port="7">b7</td></tr>
							   <tr><td port="6">b6</td></tr>
							   <tr><td rowspan="3">old</td><td port="5">b5</td></tr>
							   <tr><td port="4">b4</td></tr>
							   <tr><td port="3">b3</td></tr>
							   <tr><td rowspan="3">old</td><td port="2">b2</td></tr>
							   <tr><td port="1">b1</td></tr>
							   <tr><td port="0">b0</td></tr>
							   </table>> ];
				  label = "SCZ OUT";
				  }


		 subgraph cluster_out_for_add_sub_1 {
				  color=blue;
				  node[style=filled];
