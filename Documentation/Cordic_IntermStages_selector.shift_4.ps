%!PS-Adobe-3.0
%%BoundingBox: 0 0 595 842
%%Pages: 6

64 dict begin

%%BeginProlog

% set the list from top to bottom in an array
/cellsdraw
{
	% check the largest one
	dup 0 exch {
		stringwidth pop dup 2 index gt {
			exch pop
		}{
			pop
		}ifelse
	}forall
	% don't forget the title
	2 index	stringwidth pop dup 2 index gt {
		exch pop
		}{
			pop
		}ifelse
	
	8 add /cells_width exch def

	dup length exch
	aload  length 0 1 3 -1 roll 1 sub
	{
		cells_high mul dup
		cells_high add 0 exch moveto 0 cells_high neg rlineto cells_width 0 rlineto
		0 cells_high rlineto
		closepath stroke
		5 add 4 exch moveto show
	} for
	% and the title
	cells_high mul dup
	cells_high add 0 exch 1 add moveto 0 cells_high neg rlineto cells_width 0 rlineto
	0 cells_high rlineto
	closepath 0 0 0 0.3 setcmykcolor fill
	5 add 4 exch moveto 0 0 0 1 setcmykcolor show
}def


% the_list, new elems list => new list
/shift_list_reg {
	[ 3 1 roll exch 1 index length 3 1 roll aload length
	dup 3 add -1 roll dup 3 1 roll sub exch
	1 1 3 -1 roll { pop exch pop } for % delete the old ones
	dup 2 add -1 roll aload length dup 2 add -1 roll 1 index add exch roll % place the new ones
	]
}def

% from to 
/link_line_left {
	cells_high 4 -1 roll mul moveto
	180 cells_high 3 -1 roll mul lineto 20 0 rlineto % make the line horizontal before the arrow
	-10 5 rlineto 10 -5 rmoveto -10 -5 rlineto % arrow
}def
% from to 
/link_line_right {
	cells_high 4 -1 roll mul moveto
	20 cells_width add cells_high 3 -1 roll mul lineto -20 0 rlineto % make the line horizontal before the arrow
	10 5 rlineto -10 -5 rmoveto 10 -5 rlineto % arrow
}def


/One_op_draw {
	matrix currentmatrix
	10 10 translate
	(cos_in) list_reg_in cellsdraw
	matrix currentmatrix
	cells_width 0 translate
	(sin_in) list_reg_in cellsdraw
	setmatrix
	stroke

	list_left_B aload length 1 1 3 -1 roll {
		% draw from bottom to be compatible with all the arithmetic sizes
		dup 3 1 roll
		1 sub 5.5 add cells_width link_line_left
		0 0 1 setrgbcolor
		stroke
		% and draw the black b0.. arrow
		1 sub 0.5 add dup 1 add cells_width 2 mul link_line_left
		0 0 0 setrgbcolor
		stroke
	}for

	200 40 sub cells_high 4.5 mul 14 3 div sub moveto (0) show
	3 14 3 div rmoveto 200 cells_high 4.5 mul lineto
	-10 5 rlineto 10 -5 rmoveto -10 -5 rlineto
	200 40 sub cells_high 8.5 mul 14 3 div sub moveto (0) show
	3 14 3 div rmoveto 200 cells_high 8.5 mul lineto
	-10 5 rlineto 10 -5 rmoveto -10 -5 rlineto
	200 70 sub cells_high 0.5 mul 14 3 div sub moveto exch show
	3 14 3 div rmoveto 200 cells_high 0.5 mul lineto
	-10 5 rlineto 10 -5 rmoveto -10 -5 rlineto
	stroke


	
0 0 0 1 setcmykcolor
setmatrix
matrix currentmatrix
10 cells_high 12 1 1 add add mul 10 add translate
(latch) [(old b11)] cellsdraw
100 0 translate
(latch) [(add or sub)] cellsdraw
300 0 translate
(latch) [(old b11)] cellsdraw
setmatrix
matrix currentmatrix
210 10 translate
(Add or subtract) list_add_sub cellsdraw

	list_right_R aload length 1 1 3 -1 roll {
		dup 3 1 roll
		% draw from bottom to be compatible with all the arithmetic sizes
		1 sub 5.3 add 200 link_line_right
		1 0 0 setrgbcolor
		stroke
		% and draw the black b0.. arrow
		1 sub 0.5 add dup 1 add cells_width 200 add 40 sub link_line_right  % temp defore getting the 2 col width
		0 0 0 setrgbcolor
		stroke		
	}for
	list_right_G aload length 1 1 3 -1 roll {
		% draw from bottom to be compatible with all the arithmetic sizes
		1 sub 5.5 add 200 link_line_right
		0 1 0 setrgbcolor
		stroke
	}for
	list_right_O aload length 1 1 3 -1 roll {
		% draw from bottom to be compatible with all the arithmetic sizes
		1 sub 5.7 add 200 link_line_right
		1 0.5 0 setrgbcolor
		stroke
	}for
	0 0 0 setrgbcolor

	setmatrix
	matrix currentmatrix
	410 10 translate

	(cos_out) list_reg_out cellsdraw
	matrix currentmatrix
	cells_width 0 translate
	(sin_out) list_reg_out cellsdraw
	setmatrix
	setmatrix
} def

/Legenda_shifts {
	matrix currentmatrix
	140	250 translate
	0 0 0 setrgbcolor	0 40 moveto (bit as it) show
	0 0 1 setrgbcolor	0 20 moveto (bit direct) show
						0  0 moveto (  or not) show
	0 0 0 setrgbcolor
	setmatrix
	
	210 15.5 cells_high mul moveto show
} def

/Legenda_reg {
	matrix currentmatrix
	140	250 translate
	0 0 0 setrgbcolor	0 40 moveto (set) show
	0 0 0 setrgbcolor	0 20 moveto (the three) show
						0  0 moveto (latches) show
	0 0 0 setrgbcolor
	setmatrix
	
	210 15.5 cells_high mul moveto show
} def

/Legenda_extra_shifts {
	matrix currentmatrix
	140	210 translate
	0 0 0 setrgbcolor 0 80 moveto (bit as it) show
	1 0 0 setrgbcolor 0 60 moveto (bit direct) show
	1 0 0 setrgbcolor 0 40 moveto (  or not) show
	0 1 0 setrgbcolor 0 20 moveto (d. or not) show
	1 0.5 0 setrgbcolor 0 0 moveto (d. or not) show
	0 0 0 setrgbcolor
	setmatrix

	210 15.5 cells_high mul moveto show
} def

%%EndProlog


%%Page: 1 1
/Helvetica findfont 14 scalefont setfont

% set hte cells heigh
/cells_high 22 def

matrix currentmatrix

10 450 translate

/list_add_sub [(out carry)(out b2)(out b1)(out b0)(op_S b3)(op_S b2)(op_S b1)(op_S b0)(op_N b3)(op_N b2)(op_N b1)(op_N b0)(in carry)] def
/list_reg_in [(old b11) (old b10) (old b9)(old b8) (old b7) (old b6)(old b5) (old b4) (old b3)(old b2) (old b1) (old b0)] def
/list_reg_out list_reg_in def

/list_left_B [] def

/list_right_R [] def
/list_right_G [] def
/list_right_O [] def


(Clock cycle during reg_sync) Legenda_reg

('-') One_op_draw


% bottom of the page
0 -440 translate


/list_left_B [ 6.5 5.5 4.5 ] def


(First clock cycle) Legenda_shifts

('0' or '1') One_op_draw

setmatrix

showpage
%%EndPage: 1
%%Page: 2 2

/Helvetica findfont 14 scalefont setfont
/cells_high 22 def

matrix currentmatrix

10 450 translate

/list_add_sub [(out carry)(out b2)(out b1)(out b0)(op_S b3)(op_S b2)(op_S b1)(op_S b0)(op_N b3)(op_N b2)(op_N b1)(op_N b0)(in carry)] def
/list_reg_in [(old b11) (old b10) (old b9)(old b8) (old b7) (old b6)(old b5) (old b4) (old b3)(old b2) (old b1) (old b0)] def
/list_reg_out list_reg_in def
/list_reg_out list_reg_out [(out b2)(out b1)(out b0)] shift_list_reg def
/list_reg_in list_reg_in [(new b2)(new b1)(new b0)] shift_list_reg def


/list_right_R [] def
/list_right_G [] def
/list_right_O [] def

/list_left_B [ 6.5 5.5 4.5 ] def


(Second clock cycle) Legenda_shifts

(carry latch) One_op_draw

0 -430 translate

/list_reg_out list_reg_out [(out b5)(out b4)(out b3)] shift_list_reg def
/list_reg_in list_reg_in [(new b5)(new b5)(new b3)] shift_list_reg def
/list_right_O [ 7.5 8.5 14.5 ] def

/list_right_R [] def
/list_right_G [] def
/list_right_O [] def

/list_left_B [ 14.5 5.5 4.5 ] def

(Third clock cycle) Legenda_shifts

(carry latch) One_op_draw

setmatrix

showpage
%%EndPage: 2
%%Page: 3 3

/list_add_sub [(out carry)(out b2)(out b1)(out b0)(op_S b3)(op_S b2)(op_S b1)(op_S b0)(op_N b3)(op_N b2)(op_N b1)(op_N b0)(in carry)] def
/list_reg_in [(old b11) (old b10) (old b9)(old b8) (old b7) (old b6)(old b5) (old b4) (old b3)(old b2) (old b1) (old b0)] def
/list_reg_out list_reg_in def
/list_reg_in list_reg_in [(new b8)(new b7)(new b6)(new b5)(new b4)(new b3)(new b2)(new b1)(new b0)] shift_list_reg def
/list_reg_out list_reg_out [(out b8)(out b7)(out b6)(out b5)(out b4)(out b3)(out b2)(out b1)(out b0)] shift_list_reg def


/Helvetica findfont 14 scalefont setfont

% set hte cells heigh
/cells_high 22 def
matrix currentmatrix

10 450 translate

/list_right_R [] def
/list_right_G [] def
/list_right_O [] def

/list_left_B [ 14.5 14.5 14.5 ] def

(Fourth clock cycle) Legenda_shifts

(carry latch) One_op_draw

0 -440 translate

10 300 moveto (The frame is over.) show
10 280 moveto (The computation of the sine is done using a second set) show
10 260 moveto (  in which the cosine and the sine are toggled.) show
10 200 moveto (* If we are in the step one, the Z to 0, loop to the page 1.) show
10 180 moveto (* If we are in the step two, the Y to 0,) show
30 160 moveto (* If there are no extra shifts, loop to the page 1 as well.) show
30 140 moveto (* It there are extra shifts,) show
50 120 moveto (* Run the reg_sync again.) show
50 100 moveto (  Latch the high bits, sin and cosine, and the operation from the scz_out.) show 
50 80 moveto (* Run the algo as described in the following pages.-) show

setmatrix
showpage
%%EndPage: 3
%%Page: 4 4
/Helvetica findfont 14 scalefont setfont

% set hte cells heigh
/cells_high 22 def

matrix currentmatrix

10 450 translate

/list_add_sub [(out carry)(out b2)(out b1)(out b0)(op_S b3)(op_S b2)(op_S b1)(op_S b0)(op_N b3)(op_N b2)(op_N b1)(op_N b0)(in carry)] def
/list_reg_in [(old b11) (old b10) (old b9)(old b8) (old b7) (old b6)(old b5) (old b4) (old b3)(old b2) (old b1) (old b0)] def
/list_reg_out list_reg_in def

/list_left_B [] def

/list_right_R [ 7.5 6.5 5.5 ] def
/list_right_G [ 8.5 7.5 6.5 ] def
/list_right_O [ 9.5 8.5 7.5 ] def


(Clock cycle during reg_sync) Legenda_reg

('-') One_op_draw


% bottom of the page
0 -440 translate


/list_left_B [] def


(First clock cycle) Legenda_extra_shifts

('0' or '1') One_op_draw

setmatrix

showpage
%%EndPage: 4
%%Page: 5 5

/Helvetica findfont 14 scalefont setfont
/cells_high 22 def

matrix currentmatrix

10 450 translate

/list_add_sub [(out carry)(out b2)(out b1)(out b0)(op_S b3)(op_S b2)(op_S b1)(op_S b0)(op_N b3)(op_N b2)(op_N b1)(op_N b0)(in carry)] def
/list_reg_in [(old b11) (old b10) (old b9)(old b8) (old b7) (old b6)(old b5) (old b4) (old b3)(old b2) (old b1) (old b0)] def
/list_reg_out list_reg_in def
/list_reg_out list_reg_out [(out b2)(out b1)(out b0)] shift_list_reg def
/list_reg_in list_reg_in [(new b2)(new b1)(new b0)] shift_list_reg def


/list_right_R [ 7.5 6.5 5.5 ] def
/list_right_G [ 8.5 7.5 6.5 ] def
/list_right_O [ 14.5 8.5 7.5 ] def

/list_left_B [] def


(Second clock cycle) Legenda_extra_shifts

(carry latch) One_op_draw

0 -430 translate

/list_reg_out list_reg_out [(out b5)(out b4)(out b3)] shift_list_reg def
/list_reg_in list_reg_in [(new b5)(new b5)(new b3)] shift_list_reg def
/list_right_O [ 7.5 8.5 14.5 ] def

/list_right_R [ 14.5 14.5 5.5 ] def
/list_right_G [ 14.5 14.5 14.5 ] def
/list_right_O [ 14.5 14.5 14.5 ] def

/list_left_B [] def

(Third clock cycle) Legenda_extra_shifts

(carry latch) One_op_draw

setmatrix

showpage
%%EndPage: 5
%%Page: 6 6

/list_add_sub [(out carry)(out b2)(out b1)(out b0)(op_S b3)(op_S b2)(op_S b1)(op_S b0)(op_N b3)(op_N b2)(op_N b1)(op_N b0)(in carry)] def
/list_reg_in [(old b11) (old b10) (old b9)(old b8) (old b7) (old b6)(old b5) (old b4) (old b3)(old b2) (old b1) (old b0)] def
/list_reg_out list_reg_in def
/list_reg_in list_reg_in [(new b8)(new b7)(new b6)(new b5)(new b4)(new b3)(new b2)(new b1)(new b0)] shift_list_reg def
/list_reg_out list_reg_out [(out b8)(out b7)(out b6)(out b5)(out b4)(out b3)(out b2)(out b1)(out b0)] shift_list_reg def


/Helvetica findfont 14 scalefont setfont

% set hte cells heigh
/cells_high 22 def
matrix currentmatrix

10 450 translate

/list_right_R [ 14.5 14.5 14.5 ] def
/list_right_G [ 14.5 14.5 14.5 ] def
/list_right_O [ 14.5 14.5 14.5 ] def

/list_left_B [] def

(Fourth clock cycle) Legenda_extra_shifts

(carry latch) One_op_draw

0 -440 translate

10 300 moveto (The frame is over.) show
10 280 moveto (The computation of the sine is done using a second set) show
10 260 moveto (  in which the cosine and the sine are toggled.) show
10 200 moveto (We are here because we are in the step two, the Y to 0, and some extra shifts.) show
10 180 moveto (* If we have more extra shifts to run, loop to the page 3.) show
10 160 moveto (  while considering the green rather than the red, the orange rather than the green, etc...) show
10 140 moveto (* It there are no extra shifts and no strobe,) show
10 120 moveto (  do nothing or do irrelevant things, as the next stage is not going to listen.) show
10 100 moveto (* It the strobe is active, loop to the page 1.) show

setmatrix
showpage
%%EndPage: 6
end

